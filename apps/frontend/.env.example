# Copy to .env.local to override. All frontend env vars must be VITE_-prefixed.

# Backend API base URL. Leave empty in dev — requests go through the Vite proxy.
VITE_API_URL=

# OIDC (defaults target the dockerized Keycloak realm from GP-6; override for prod).
VITE_OIDC_ISSUER=http://localhost:8085/realms/groundplan
VITE_OIDC_CLIENT_ID=groundplan-frontend
VITE_OIDC_REDIRECT_URI=http://localhost:5173/callback
