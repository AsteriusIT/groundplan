---
// Landing page — commercial pass. Order follows the conversion journey:
// promise → pain → how → product tour → trust → AI → K8s → DX → deployment
// → FAQ → closing CTA.
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import Problem from "../components/Problem.astro";
import HowItWorks from "../components/HowItWorks.astro";
import ProductTour from "../components/ProductTour.astro";
import SecurityBand from "../components/SecurityBand.astro";
import AiSection from "../components/AiSection.astro";
import K8sSection from "../components/K8sSection.astro";
import DevExperience from "../components/DevExperience.astro";
import SelfHostFaq from "../components/SelfHostFaq.astro";

// §14 one-paragraph summary — the meta description, verbatim (GP-164).
const META_DESCRIPTION =
  "Groundplan turns Terraform and Kubernetes into living, interactive architecture diagrams. It renders every pull request as a visual change — with blast radius, security exposure and permission risks — and regenerates your documentation on every merge. It reads only the plan JSON and manifests your own CI produces: no cloud credentials, no state access, ever. With network, IAM and C4 lenses, a human annotation layer, an honest opt-in AI, a CLI, a live VS Code preview and one-file self-hosting, it's infrastructure review the way it should have always worked: visible.";
---

<Base
  title="Groundplan — See your infrastructure. Review it. Shape it."
  description={META_DESCRIPTION}
>
  <Hero />
  <Problem />
  <HowItWorks />
  <ProductTour />
  <SecurityBand />
  <AiSection />
  <K8sSection />
  <DevExperience />
  <SelfHostFaq />
</Base>
