---
// The one layout (GP-158): header nav, footer title block, meta.
// Security sits in nav position 2 by design — it is the objection-killer
// (GP-161, §12 of docs/website-presentation.md).
import "../styles/global.css";
import { APP_URL } from "../urls.js";

interface Props {
  title: string;
  description?: string;
  /** OG image path; defaults to the hero export rasterized (GP-164). */
  ogImage?: string;
}

const { title, description, ogImage = "/images/og-image.png" } = Astro.props;
const ogImageUrl = new URL(ogImage, Astro.site);
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);

const NAV = [
  { href: "/#product", label: "Product" },
  { href: "/#how", label: "How it works" },
  { href: "/security/", label: "Security" },
  { href: "/#faq", label: "FAQ" },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Staging stays out of the index until the trademark gate (GP-166) clears. -->
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="471" />
    <meta name="twitter:card" content="summary_large_image" />
    <!-- Gate for the scroll-reveal styles: without JS nothing is ever hidden. -->
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:bg-card focus:px-4 focus:py-2 focus:text-sm focus:border focus:border-border-strong"
    >
      Skip to content
    </a>

    <header class="border-b border-border bg-card">
      <div class="mx-auto flex max-w-6xl items-center justify-between gap-6 px-4 py-3 sm:px-6">
        <a href="/" class="flex items-baseline gap-2">
          <span class="font-display text-lg font-semibold tracking-tight">groundplan</span>
          <span class="hidden font-mono text-[11px] text-faint sm:inline">rev&nbsp;A</span>
        </a>
        <nav aria-label="Main" class="flex items-center gap-2 sm:gap-4">
          <ul class="flex items-center gap-1 sm:gap-2">
            {
              NAV.map((item) => (
                <li class:list={[item.label === "How it works" && "hidden sm:block"]}>
                  <a
                    href={item.href}
                    aria-current={currentPath === item.href ? "page" : undefined}
                    class:list={[
                      "whitespace-nowrap px-2 py-1.5 text-sm sm:px-3",
                      currentPath === item.href
                        ? "text-foreground font-medium"
                        : "text-muted-foreground hover:text-foreground",
                    ]}
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
          <a
            href={APP_URL}
            class="hidden bg-primary px-4 py-2 text-sm font-medium text-primary-foreground transition hover:opacity-90 sm:inline-block"
          >
            Open the app <span aria-hidden="true">↗</span>
          </a>
        </nav>
      </div>
    </header>

    <main id="main" class="flex-1">
      <slot />
    </main>

    <!-- Footer as an engineering-drawing title block: the site is a drawing
         sheet, so it ends the way a drawing does. -->
    <footer class="border-t border-border-strong bg-card">
      <div class="mx-auto max-w-6xl px-4 py-6 sm:px-6">
        <div
          class="grid grid-cols-2 divide-x divide-border border border-border-strong font-mono text-[11px] sm:grid-cols-4"
        >
          <div class="p-3">
            <div class="text-faint uppercase tracking-wider">Project</div>
            <div class="mt-1 text-foreground">Groundplan</div>
          </div>
          <div class="p-3">
            <div class="text-faint uppercase tracking-wider">Drawn by</div>
            <div class="mt-1 text-foreground">AsteriusIT</div>
          </div>
          <div class="p-3">
            <div class="text-faint uppercase tracking-wider">Scale</div>
            <div class="mt-1 text-foreground">1:1 — always in sync</div>
          </div>
          <div class="p-3">
            <div class="text-faint uppercase tracking-wider">Status</div>
            <div class="mt-1 text-foreground">Preview — not indexed</div>
          </div>
        </div>
        <slot name="footer-extra" />
        <p class="mt-4 text-xs text-muted-foreground">
          © {new Date().getFullYear()} AsteriusIT. Legal notice and privacy policy to follow.
        </p>
      </div>
    </footer>

    <script>
      // Scroll reveal: flip data-reveal elements visible once, then let go.
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              io.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.1, rootMargin: "0px 0px -60px 0px" },
      );
      document.querySelectorAll("[data-reveal]").forEach((el) => io.observe(el));
    </script>
  </body>
</html>
