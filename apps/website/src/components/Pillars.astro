---
// The three pillars (GP-160), §3 of docs/website-presentation.md. Copy blocks
// verbatim; screenshots captured from the real app on asteriusit/
// groundplan-example (see assets-src/) — no mockups, no lorem-ipsum diagrams.
import Pillar from "./Pillar.astro";

const SEE_FACTS = [
  {
    text: "Plan JSON → graph producer with explicit depends_on and expression-inferred dependencies.",
    stories: ["GP-13", "GP-20", "GP-21"],
  },
  {
    text: "Impact propagation: unchanged dependents are marked “impacted” with distance, framing the true blast radius.",
    stories: ["GP-22"],
  },
  {
    text: "Attribute-level before → after diff on every node, with sensitive values masked.",
    stories: ["GP-32"],
  },
  {
    text: "Deterministic change summary — rule-based Markdown (deletions first), identical output for identical input, no AI required.",
    stories: ["GP-36"],
  },
  {
    text: "Risk badges: Exposed (internet-facing via NSG analysis) and Privileged (high-privilege IAM at broad scope) flagged on nodes, PR rows and the dashboard.",
    stories: ["GP-43", "GP-47"],
  },
  {
    text: "PR comments on GitHub, GitLab and Azure DevOps: one idempotent comment per plan snapshot with an embedded changes-only PNG and a link to the interactive diagram.",
    stories: ["GP-38", "GP-53", "GP-54"],
  },
  {
    text: "PR lifecycle: PRs are fed by the webhook, soft-closed when the branch is deleted, history kept.",
    stories: ["GP-107", "GP-109"],
  },
];

const UNDERSTAND_FACTS = [
  {
    text: "Docs of main from static HCL parsing, auto-regenerated on merge by a background ref poller — zero user action.",
    stories: ["GP-15", "GP-23", "GP-107", "GP-108"],
  },
  {
    text: "Snapshot history timeline + compare mode: diff two documentation versions (added / removed / moved) with a summary strip.",
    stories: ["GP-26", "GP-40"],
  },
  {
    text: "Network view: real vnet ⊃ subnet ⊃ resource containment, NSG rule inspection, internet-exposure highlighting, hub-edge taming.",
    stories: ["GP-42", "GP-43", "GP-44", "GP-45"],
  },
  {
    text: "IAM view: principal → role → scope table with privileged-assignment flags and drill-down to source.",
    stories: ["GP-47", "GP-48", "GP-49"],
  },
  {
    text: "C4 view: your annotation groups collapsed to one node per system, with aggregated edge counts and drill-into-group.",
    stories: ["GP-77"],
  },
  {
    text: "Server-rendered SVG/PNG export, cached and deterministic, plus “changes only” export on PRs.",
    stories: ["GP-37"],
  },
  {
    text: "Public share links: tokenized, read-only, no login — “always latest” or pinned to a version, revocable, rate-limited, never exposing AI content.",
    stories: ["GP-39"],
  },
];

const SHAPE_FACTS = [
  {
    text: "Five annotation types — note, link, group, hide, rename — anchored to Terraform addresses, stored beside (never inside) the snapshot.",
    stories: ["GP-56", "GP-71"],
  },
  {
    text: "Adapted view: a pure projection folds annotations into an ordinary graph, so the renderer needs no special cases.",
    stories: ["GP-72", "GP-73", "GP-74"],
  },
  {
    text: "Orphan reconciliation: when an anchor's address vanishes, the annotation flips to orphaned and a review tray offers re-anchor / keep / delete — and the flip reverses itself if the resource comes back.",
    stories: ["GP-57", "GP-59"],
  },
  {
    text: "AI-proposed annotations arrive in a review inbox, never on the canvas, each with a one-sentence reason; a human accepts, edits or dismisses every one. Provenance (human vs AI) is permanent.",
    stories: ["GP-75", "GP-76"],
  },
  {
    text: "Project & repository context: long-form Markdown that documents intent and grounds the AI summaries.",
    stories: ["GP-60"],
  },
];
---

<div id="pillars">
  <Pillar
    id="see"
    index={1}
    verb="See"
    title="Visual pull-request review"
    facts={SEE_FACTS}
    image={{
      src: "/images/pillar-see.png",
      alt: "The Groundplan PR view for pull request 42: the plan-impact diagram with created, updated, deleted and impacted resources coloured, and the deterministic change summary panel beside the canvas.",
      caption:
        "PR #42 in asteriusit/groundplan-example — plan impact, risk-aware summary, Network and IAM tabs.",
    }}
  >
    <p>
      Open a PR, get a diagram. Groundplan parses the
      <code class="font-mono text-sm">terraform plan</code> JSON your CI already produces and
      draws the change: green for created, amber for updated, red (dashed, struck through) for
      destroyed — and violet for the resources you <em>didn't</em> touch but that depend on
      what you did. The unchanged estate is ghosted so the change dominates the canvas.
    </p>
  </Pillar>

  <Pillar
    id="understand"
    index={2}
    verb="Understand"
    title="Living documentation & lenses"
    facts={UNDERSTAND_FACTS}
    flip
    image={{
      src: "/images/pillar-understand.png",
      alt: "The Groundplan documentation page on the Network lens: the vnet contains the data and web subnets, the web subnet is highlighted as internet-exposed with its NSG chip, and the Global, Adapted, C4, Network and IAM lens tabs sit above the canvas.",
      caption:
        "Docs of main, Network lens — vnet ⊃ subnet containment with internet-exposure highlighting.",
    }}
  >
    <p>
      Merge to main and the documentation redraws itself. Groundplan statically parses your
      HCL — no plan, no apply needed — and keeps a versioned diagram of your default branch.
      Then look at the same estate through the lens that matches your question: the network,
      the permissions, the C4 big picture.
    </p>
  </Pillar>

  <Pillar
    id="shape"
    index={3}
    verb="Shape"
    title="The annotation layer"
    facts={SHAPE_FACTS}
    image={{
      src: "/images/pillar-shape.png",
      alt: "The Groundplan annotation review tray: a note that lost its anchor after the legacy storage account was removed, its address struck through, with Keep, Re-anchor and delete actions — above a canvas showing the Session store and API platform annotation groups.",
      caption:
        "The review tray: an orphaned note on the removed storage account — kept for a human to re-anchor, keep or delete, never silently dropped.",
    }}
  >
    <p>
      A generated diagram knows what exists; only your team knows what it <em>means</em>.
      Groundplan lets you group resources into systems, rename them in human language, hide
      the noise, draw the logical connections and pin notes — without ever editing the
      generated model. Your annotations survive regeneration: when a resource disappears, its
      annotations are flagged for review, never silently deleted.
    </p>
  </Pillar>
</div>
