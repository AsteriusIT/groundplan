---
// The problem — four pains, one line each. Named plainly, no lecture.
const PAINS = [
  { name: "Approved blind", text: "Reviews happen in a wall of text nobody can picture." },
  { name: "Docs that lie", text: "Diagrams are stale the day they're drawn." },
  { name: "Surprise blast radius", text: "You learn what a change touched after it ships." },
  { name: "Tools that want the keys", text: "Everything else asks for your cloud keys." },
];
---

<section aria-label="The problem" class="border-b border-border">
  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6 sm:py-16">
    <h2 class="max-w-2xl font-display text-2xl font-semibold tracking-tight sm:text-3xl" data-reveal>
      Infrastructure review is stuck in text.
    </h2>
    <ul class="mt-10 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {
        PAINS.map((pain, i) => (
          <li
            class="border-t-2 border-delete pt-4 transition-transform duration-300 hover:-translate-y-1"
            data-reveal
            style={`--reveal-delay: ${i * 90}ms`}
          >
            <p class="font-display text-base font-semibold">{pain.name}</p>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{pain.text}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
