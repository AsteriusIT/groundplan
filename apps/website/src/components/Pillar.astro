---
// One pillar section (GP-160): [copy] block in the slot, [facts] with their
// GP story numbers, one real screenshot. Facts without a story number in the
// source doc are not shown — every claim on the page must trace to a story.
interface Fact {
  text: string;
  stories: string[];
}

interface Props {
  id: string;
  index: number;
  verb: string;
  title: string;
  facts: Fact[];
  image: { src: string; alt: string; caption: string };
  flip?: boolean;
}

const { id, index, verb, title, facts, image, flip = false } = Astro.props;
---

<section id={id} class="border-b border-border">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20">
    <p class="font-mono text-xs uppercase tracking-widest text-muted-foreground">
      Pillar {index} of 3
    </p>
    <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight sm:text-4xl">
      <span class="text-primary">{verb}</span> — {title}
    </h2>

    <div
      class:list={[
        "mt-8 grid items-start gap-10 lg:grid-cols-2",
      ]}
    >
      <div class:list={[flip && "lg:order-2"]}>
        <div class="max-w-prose text-base leading-relaxed text-muted-foreground">
          <slot />
        </div>
        <ul class="mt-6 space-y-3 border-t border-border pt-6">
          {
            facts.map((fact) => (
              <li class="flex gap-3 text-sm leading-relaxed">
                <span aria-hidden="true" class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-primary"></span>
                <span>
                  {fact.text}
                  <span class="ml-1 whitespace-nowrap font-mono text-[11px] text-faint">
                    {fact.stories.join(" · ")}
                  </span>
                </span>
              </li>
            ))
          }
        </ul>
      </div>

      <figure class:list={[flip && "lg:order-1"]}>
        <div class="overflow-hidden border border-border-strong bg-card shadow-sm">
          <img
            src={image.src}
            alt={image.alt}
            width="2880"
            height="1800"
            loading="lazy"
            class="block h-auto w-full"
          />
        </div>
        <figcaption class="mt-2 font-mono text-[11px] text-faint">{image.caption}</figcaption>
      </figure>
    </div>
  </div>
</section>
