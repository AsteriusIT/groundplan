---
// How it works — three steps a visitor can picture themselves doing. The
// numbers are real sequence, not decoration: this is the actual adoption
// path, and step one is the whole integration.
const CLI_SNIPPET = "npx @asteriusit/cli push-plan --file plan.json";
---

<section id="how" class="border-b border-border">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-24">
    <p class="font-mono text-xs uppercase tracking-widest text-muted-foreground">How it works</p>
    <h2 class="mt-3 max-w-2xl font-display text-3xl font-semibold tracking-tight sm:text-4xl">
      From code to picture in three steps
    </h2>

    <ol class="mt-12 grid gap-10 lg:grid-cols-3">
      <li class="relative border-l-2 border-primary pl-6 lg:border-l-0 lg:border-t-2 lg:pl-0 lg:pt-6">
        <p class="font-mono text-sm text-primary">01</p>
        <h3 class="mt-2 font-display text-xl font-semibold">Add one line to your CI</h3>
        <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
          Your pipeline already produces a Terraform plan — send it to Groundplan. No agents,
          no credentials, nothing installed in your cloud.
        </p>
        <div class="mt-4 flex items-stretch border border-border-strong bg-card">
          <pre
            class="flex-1 overflow-x-auto px-3 py-2 font-mono text-xs leading-relaxed"><code id="cli-snippet">{CLI_SNIPPET}</code></pre>
          <button
            type="button"
            id="copy-cli"
            class="border-l border-border-strong px-3 font-mono text-[11px] uppercase tracking-wider text-muted-foreground hover:bg-accent hover:text-accent-foreground"
            data-snippet={CLI_SNIPPET}
          >
            Copy
          </button>
        </div>
      </li>
      <li class="relative border-l-2 border-primary pl-6 lg:border-l-0 lg:border-t-2 lg:pl-0 lg:pt-6">
        <p class="font-mono text-sm text-primary">02</p>
        <h3 class="mt-2 font-display text-xl font-semibold">Open a pull request</h3>
        <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
          The PR gets a diagram: what's created, what changes, what's removed — and what it
          impacts. Reviewers see the blast radius before they approve, right in GitHub, GitLab
          or Azure DevOps.
        </p>
      </li>
      <li class="relative border-l-2 border-primary pl-6 lg:border-l-0 lg:border-t-2 lg:pl-0 lg:pt-6">
        <p class="font-mono text-sm text-primary">03</p>
        <h3 class="mt-2 font-display text-xl font-semibold">Merge — the docs update themselves</h3>
        <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
          Every merge to main redraws your architecture documentation. Versioned, shareable
          with a read-only link, and never stale again.
        </p>
      </li>
    </ol>
  </div>
</section>

<script>
  const button = document.getElementById("copy-cli");
  button?.addEventListener("click", async () => {
    const snippet = button.dataset.snippet ?? "";
    try {
      await navigator.clipboard.writeText(snippet);
      button.textContent = "Copied";
      setTimeout(() => (button.textContent = "Copy"), 1500);
    } catch {
      button.textContent = "Select & copy";
    }
  });
</script>
