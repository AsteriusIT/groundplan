---
// How it works — three steps, each short enough to picture. The numbers are
// real sequence: this is the adoption path, and step one is the whole
// integration.
import { STACK_ICONS } from "./stack-icons.js";

const CLI_SNIPPET = "npx @asteriusit/cli push-plan --file plan.json";
const GIT_HOSTS = STACK_ICONS.filter((icon) =>
  ["GitHub", "GitLab", "Azure DevOps"].includes(icon.label),
);
---

<section id="how" class="border-b border-border bg-card">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-24">
    <p class="font-mono text-xs uppercase tracking-widest text-muted-foreground" data-reveal>
      How it works
    </p>
    <h2
      class="mt-3 max-w-2xl font-display text-3xl font-semibold tracking-tight sm:text-4xl"
      data-reveal
    >
      From code to picture in three steps
    </h2>

    <ol class="mt-12 grid gap-10 lg:grid-cols-3">
      <li
        class="relative border-l-2 border-primary pl-6 lg:border-l-0 lg:border-t-2 lg:pl-0 lg:pt-6"
        data-reveal
      >
        <p class="font-mono text-sm text-primary">01</p>
        <h3 class="mt-2 font-display text-xl font-semibold">Add one line to your CI</h3>
        <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
          Your CI already produces a plan — send it. No agents, nothing installed in your
          cloud.
        </p>
        <div class="mt-4 flex items-stretch border border-border-strong bg-background">
          <pre
            class="flex-1 whitespace-pre-wrap px-3 py-2 font-mono text-xs leading-relaxed [overflow-wrap:anywhere]"><code id="cli-snippet">{CLI_SNIPPET}</code></pre>
          <button
            type="button"
            id="copy-cli"
            class="border-l border-border-strong px-3 font-mono text-[11px] uppercase tracking-wider text-muted-foreground transition hover:bg-accent hover:text-accent-foreground"
            data-snippet={CLI_SNIPPET}
          >
            Copy
          </button>
        </div>
      </li>
      <li
        class="relative border-l-2 border-primary pl-6 lg:border-l-0 lg:border-t-2 lg:pl-0 lg:pt-6"
        data-reveal
        style="--reveal-delay: 120ms"
      >
        <p class="font-mono text-sm text-primary">02</p>
        <h3 class="mt-2 font-display text-xl font-semibold">Open a pull request</h3>
        <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
          The PR gets a diagram: created, changed, removed — and the blast radius. Reviewers
          see it before they approve.
        </p>
        <ul class="mt-4 flex items-center gap-4">
          {
            GIT_HOSTS.map((host) => (
              <li class="flex items-center gap-2">
                <svg viewBox="0 0 24 24" width="18" height="18" fill={host.fill} aria-hidden="true">
                  <path d={host.path} />
                </svg>
                <span class="text-xs text-muted-foreground">{host.label}</span>
              </li>
            ))
          }
        </ul>
      </li>
      <li
        class="relative border-l-2 border-primary pl-6 lg:border-l-0 lg:border-t-2 lg:pl-0 lg:pt-6"
        data-reveal
        style="--reveal-delay: 240ms"
      >
        <p class="font-mono text-sm text-primary">03</p>
        <h3 class="mt-2 font-display text-xl font-semibold">Merge — the docs update themselves</h3>
        <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
          Every merge redraws your architecture docs. Versioned, shareable, never stale.
        </p>
      </li>
    </ol>
  </div>
</section>

<script>
  const button = document.getElementById("copy-cli");
  button?.addEventListener("click", async () => {
    const snippet = button.dataset.snippet ?? "";
    try {
      await navigator.clipboard.writeText(snippet);
      button.textContent = "Copied";
      setTimeout(() => (button.textContent = "Copy"), 1500);
    } catch {
      button.textContent = "Select & copy";
    }
  });
</script>
