---
// The objection-killer, given the visual weight it earns: the one light
// "paper" band on the carbon page (bg-ink — the ink token is the light
// neutral on this theme). Three proofs, one line each.
const PROOFS = [
  { title: "No cloud credentials", text: "There is nothing to leak — we never hold access." },
  { title: "No state access", text: "Your state never leaves your pipeline." },
  { title: "Nothing executed", text: "No terraform, helm or kustomize — ever. We ingest what your CI renders." },
];
---

<section id="security" aria-label="Security" class="border-b border-border bg-ink text-primary-foreground">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-24">
    <p class="font-mono text-xs uppercase tracking-widest text-primary-foreground/60" data-reveal>
      Security
    </p>
    <h2 class="mt-3 max-w-3xl font-display text-3xl font-semibold tracking-tight sm:text-4xl" data-reveal>
      We ingest data, not access.
    </h2>
    <p
      class="mt-5 max-w-2xl text-base leading-relaxed text-primary-foreground/75"
      data-reveal
      style="--reveal-delay: 100ms"
    >
      That's the whole trust model — designed so your security team can say yes.
    </p>

    <div class="mt-12 grid gap-8 sm:grid-cols-3">
      {
        PROOFS.map((proof, i) => (
          <div
            class="border-t border-primary-foreground/25 pt-5"
            data-reveal
            style={`--reveal-delay: ${i * 110}ms`}
          >
            <h3 class="font-display text-lg font-semibold">{proof.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-primary-foreground/75">{proof.text}</p>
          </div>
        ))
      }
    </div>

    <div class="mt-12" data-reveal>
      <a
        href="/security/"
        class="inline-block bg-primary-foreground px-6 py-3 text-sm font-medium text-ink transition hover:opacity-90"
      >
        Read the full security model
      </a>
    </div>
  </div>
</section>
