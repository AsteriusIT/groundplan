---
// AI, sold the way we build it: the diagrams are deterministic, the AI is
// optional prose beside them. "Experimental" and "Azure-focused" stay in the
// section itself, never a footnote.
const STUDIO_POINTS = [
  "Watch the Terraform being written and the diagram grow node by node as you talk.",
  "Instant best-practice findings on the generated code — open ports, exposed SSH, weak TLS and more.",
  "Download the project as a zip and run the plan yourself. Nothing is deployed, nothing is stored.",
];
---

<section id="ai" class="border-b border-border bg-card">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-24">
    <p class="font-mono text-xs uppercase tracking-widest text-muted-foreground">AI, opt-in</p>
    <h2 class="mt-3 max-w-2xl font-display text-3xl font-semibold tracking-tight sm:text-4xl">
      AI that explains — and never decides
    </h2>
    <p class="mt-6 max-w-3xl text-base leading-relaxed text-muted-foreground">
      Your diagrams are deterministic: same input, same picture, every time. AI sits beside
      them, summarising changes in plain language and suggesting how to group your systems —
      always labelled, always reviewed by a human. And it never reads your raw plan files:
      every generation is grounded in Groundplan's own deterministic outputs. Don't want AI?
      Don't configure it — without an API key, the AI layer simply doesn't exist.
    </p>

    <div class="mt-14 grid items-center gap-10 lg:grid-cols-2 lg:gap-14">
      <div>
        <div class="flex flex-wrap items-center gap-2">
          <h3 class="font-display text-2xl font-semibold tracking-tight">
            AI Infrastructure Studio
          </h3>
          <span class="border border-warning bg-warning-soft px-2 py-0.5 font-mono text-[11px] uppercase tracking-wider text-warning">
            Experimental
          </span>
          <span class="border border-border-strong bg-accent-soft px-2 py-0.5 font-mono text-[11px] uppercase tracking-wider text-accent-foreground">
            Azure-focused
          </span>
        </div>
        <p class="mt-4 max-w-prose text-base leading-relaxed text-muted-foreground">
          Describe the infrastructure you want in plain English and watch the architecture
          appear on the canvas — Terraform included. You stay in control of every line.
        </p>
        <ul class="mt-6 space-y-3">
          {
            STUDIO_POINTS.map((point) => (
              <li class="flex gap-3 text-sm leading-relaxed">
                <span aria-hidden="true" class="mt-0.5 font-mono text-create">✓</span>
                <span>{point}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <figure>
        <div class="overflow-hidden border border-border-strong bg-card shadow-lg shadow-ink/5">
          <img
            src="/images/studio.png"
            alt="The AI Infrastructure Studio start screen with its header reading AI Infrastructure Studio, an AZURE label and an Experimental badge, a prompt box asking what should we build, and example prompts for Azure infrastructure."
            width="2880"
            height="1800"
            loading="lazy"
            class="block h-auto w-full"
          />
        </div>
        <figcaption class="mt-2 font-mono text-[11px] text-faint">
          The Studio as it ships: Experimental badge in the header, Azure scope declared.
        </figcaption>
      </figure>
    </div>
  </div>
</section>
