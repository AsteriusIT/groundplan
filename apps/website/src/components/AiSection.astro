---
// AI + Infrastructure Studio (GP-162), §4 of docs/website-presentation.md.
// "Experimental" and "Azure-focused" live in the section itself, never a
// footnote; the no-key-no-AI rule is stated in the body.
const STUDIO_FACTS = [
  {
    text: "Streaming chat that regenerates a full Terraform project each turn, with an ephemeral parse to a diagram and progressive node highlighting.",
    stories: ["GP-137", "GP-138", "GP-142"],
  },
  {
    text: "Code viewer with node ↔ file navigation and zip download.",
    stories: ["GP-143"],
  },
  {
    text: "Deterministic lint pass on generated HCL: 12 in-house security and best-practice rules (open NSG, exposed SSH/RDP, hardcoded secrets, public storage, weak TLS, VM password auth…) shown as severity badges.",
    stories: ["GP-139"],
  },
  {
    text: "Sessions are in-memory only — nothing is stored.",
    stories: ["GP-141"],
  },
];
---

<section id="ai" class="border-b border-border bg-card">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20">
    <p class="font-mono text-xs uppercase tracking-widest text-muted-foreground">
      AI, done honestly
    </p>
    <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight sm:text-4xl">
      The AI never replaces the deterministic view
    </h2>
    <p class="mt-6 max-w-3xl text-base leading-relaxed text-muted-foreground">
      Groundplan's AI never replaces the deterministic view — it sits beside it. And it never
      reads your plan files: every generation is grounded in a brief rendered from
      Groundplan's own deterministic outputs. No API key configured? The AI layer doesn't
      exist — no surfaces, no calls, no surprises.
    </p>
    <p class="mt-4 max-w-3xl border-l-2 border-primary bg-background p-4 font-mono text-sm">
      <code>AI_API_KEY</code> unset ⇒ the AI layer doesn't exist: the routes 404 and the
      frontend renders zero AI surface.
    </p>

    <div class="mt-12 grid items-start gap-10 lg:grid-cols-2">
      <div>
        <div class="flex flex-wrap items-center gap-2">
          <h3 class="font-display text-2xl font-semibold tracking-tight">
            AI Infrastructure Studio
          </h3>
          <span class="border border-warning bg-warning-soft px-2 py-0.5 font-mono text-[11px] uppercase tracking-wider text-warning">
            Experimental
          </span>
          <span class="border border-border-strong bg-accent-soft px-2 py-0.5 font-mono text-[11px] uppercase tracking-wider text-accent-foreground">
            Azure-focused
          </span>
        </div>
        <p class="mt-4 max-w-prose text-base leading-relaxed text-muted-foreground">
          Describe the infrastructure you want in plain English; watch the Terraform being
          written and the architecture appear, node by node, on the canvas. Inspect any
          resource's generated HCL, get instant best-practice findings, and download the
          project as a zip — then run <code class="font-mono text-sm">terraform plan</code>
          yourself, because you stay in control.
        </p>
        <ul class="mt-6 space-y-3 border-t border-border pt-6">
          {
            STUDIO_FACTS.map((fact) => (
              <li class="flex gap-3 text-sm leading-relaxed">
                <span aria-hidden="true" class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-primary"></span>
                <span>
                  {fact.text}
                  <span class="ml-1 whitespace-nowrap font-mono text-[11px] text-faint">
                    {fact.stories.join(" · ")}
                  </span>
                </span>
              </li>
            ))
          }
        </ul>
      </div>

      <figure>
        <div class="overflow-hidden border border-border-strong bg-card shadow-sm">
          <img
            src="/images/studio.png"
            alt="The AI Infrastructure Studio start screen with its header reading AI Infrastructure Studio, an AZURE label and an Experimental badge, a prompt box asking what should we build, and example prompts for Azure infrastructure."
            width="2880"
            height="1800"
            loading="lazy"
            class="block h-auto w-full"
          />
        </div>
        <figcaption class="mt-2 font-mono text-[11px] text-faint">
          The Studio as it ships: Experimental badge in the header, Azure scope declared,
          nothing deployed, nothing stored.
        </figcaption>
      </figure>
    </div>
  </div>
</section>
