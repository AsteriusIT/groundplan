---
// Kubernetes — the same promise, honestly scoped, with the marks on show.
import { STACK_ICONS } from "./stack-icons.js";

const K8S_ICONS = STACK_ICONS.filter((icon) => ["Kubernetes", "Helm"].includes(icon.label));

const POINTS = [
  "PRs reviewed by structural diff — no plan file needed.",
  "Helm and Kustomize rendered by your CI — never executed by us.",
  "Clusters read-only; Secret values never fetched, stored or drawn.",
];
---

<section id="kubernetes" class="border-b border-border">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-24">
    <div class="flex items-center gap-3" data-reveal>
      <p class="font-mono text-xs uppercase tracking-widest text-muted-foreground">Kubernetes</p>
      {
        K8S_ICONS.map((icon) => (
          <svg viewBox="0 0 24 24" width="18" height="18" fill={icon.fill} aria-hidden="true">
            <path d={icon.path} />
          </svg>
        ))
      }
    </div>
    <h2
      class="mt-3 max-w-2xl font-display text-3xl font-semibold tracking-tight sm:text-4xl"
      data-reveal
    >
      Kubernetes gets the same loop
    </h2>
    <p
      class="mt-6 max-w-2xl text-base leading-relaxed text-muted-foreground"
      data-reveal
      style="--reveal-delay: 100ms"
    >
      Point it at a manifests repo: main documented, PRs reviewed — as pictures. Attach a
      live cluster, read-only.
    </p>
    <ul class="mt-8 max-w-2xl space-y-3">
      {
        POINTS.map((point, i) => (
          <li
            class="flex gap-3 text-sm leading-relaxed"
            data-reveal
            style={`--reveal-delay: ${i * 90}ms`}
          >
            <span aria-hidden="true" class="mt-0.5 font-mono text-cat-network">✓</span>
            <span>{point}</span>
          </li>
        ))
      }
    </ul>
    <p
      class="mt-8 max-w-2xl border-l-2 border-warning bg-warning-soft p-4 text-sm leading-relaxed"
      data-reveal
    >
      Honest scope: Kubernetes snapshots get the diagram and its deterministic summary today —
      annotations, AI and share links are Terraform-first for now.
    </p>
  </div>
</section>
