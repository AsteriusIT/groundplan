---
// Run-it-your-way, the FAQ security teams ask first, and the closing CTA.
// FAQ answers are kept verbatim from the presentation doc — they are already
// the commercial pitch, honestly worded. Plain <details>, no JS accordion.
const FAQ: { q: string; a: string }[] = [
  {
    q: "Do you need access to our cloud account?",
    a: "No. Groundplan never holds cloud credentials or state. Your CI sends us the plan JSON it already produces.",
  },
  {
    q: "Do you run Terraform, Helm or Kustomize?",
    a: "Never. Rendering happens in your CI; we ingest the output.",
  },
  {
    q: "What does the AI see?",
    a: "A Markdown brief rendered from Groundplan's own deterministic outputs — never your raw plan files. And with no API key configured, the AI layer is entirely absent.",
  },
  {
    q: "Can we self-host?",
    a: "Yes — the whole platform, including the identity provider, from one compose file with automatic HTTPS.",
  },
  {
    q: "What if a diagram can't be fully built?",
    a: "It says so. Partial diagrams carry explicit warnings; we never silently store an empty or misleading graph.",
  },
  {
    q: "Does the VS Code extension send our code anywhere?",
    a: "No. It parses locally, works fully offline and contains no telemetry.",
  },
];
---

<section id="selfhost" class="border-b border-border">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-24">
    <p class="font-mono text-xs uppercase tracking-widest text-muted-foreground">
      Self-host or SaaS
    </p>
    <h2 class="mt-3 max-w-2xl font-display text-3xl font-semibold tracking-tight sm:text-4xl">
      Run it your way
    </h2>
    <div class="mt-10 grid gap-8 lg:grid-cols-2">
      <div class="border border-border bg-card p-6">
        <h3 class="font-display text-xl font-semibold">Self-host in an afternoon</h3>
        <p class="mt-4 text-sm leading-relaxed text-muted-foreground">
          The entire platform — reverse proxy with automatic HTTPS, frontend, API, database,
          identity provider — from one compose file. No managed services, no external
          dependencies, nothing that phones home.
        </p>
      </div>
      <div class="border border-border bg-card p-6">
        <h3 class="font-display text-xl font-semibold">Or let us run it</h3>
        <p class="mt-4 text-sm leading-relaxed text-muted-foreground">
          SaaS mode is the same build with one flag — same features, same security model.
          Sign in with any OIDC identity provider, or use the branded one that ships in the
          box. And in production it refuses to start misconfigured: fail-closed, not
          fail-open.
        </p>
      </div>
    </div>
  </div>
</section>

<section id="faq" class="border-b border-border bg-card">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-24">
    <p class="font-mono text-xs uppercase tracking-widest text-muted-foreground">FAQ</p>
    <h2 class="mt-3 max-w-2xl font-display text-3xl font-semibold tracking-tight sm:text-4xl">
      The questions security teams ask first
    </h2>
    <div class="mt-8 max-w-3xl divide-y divide-border border border-border bg-background">
      {
        FAQ.map((item) => (
          <details class="group px-5 py-4">
            <summary class="cursor-pointer list-none font-medium marker:content-none">
              <span class="mr-2 inline-block font-mono text-xs text-primary group-open:rotate-90 motion-reduce:transition-none">
                ▸
              </span>
              {item.q}
            </summary>
            <p class="mt-3 pl-5 text-sm leading-relaxed text-muted-foreground">{item.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>

<section aria-label="Get started" class="blueprint-grid border-b border-border">
  <div class="mx-auto max-w-6xl px-4 py-24 text-center sm:px-6">
    <h2 class="mx-auto max-w-2xl font-display text-3xl font-semibold tracking-tight sm:text-4xl">
      One pipeline step away from seeing your infrastructure.
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-muted-foreground">
      Groundplan is in private preview. Start with the part your security team will ask about
      anyway.
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
      <a
        href="/security/"
        class="bg-primary px-7 py-3 text-base font-medium text-primary-foreground shadow-lg shadow-primary/20 hover:opacity-90"
      >
        Read the security model
      </a>
      <a
        href="#product"
        class="border border-border-strong bg-card px-7 py-3 text-base font-medium text-secondary-foreground hover:border-primary hover:text-primary"
      >
        Back to the tour
      </a>
    </div>
  </div>
</section>
