---
// Hero — commercial pass. Centered composition: eyebrow, benefit headline,
// one-sentence promise, dual CTA, trust chips, then the product stage.
// The GP-165 HCL-wall → diagram sweep stays exactly as shipped: it is the
// product demo, and prefers-reduced-motion still gets the static export
// with no layout shift (the wall is absolutely positioned over the box the
// image's width/height already reserve).
const PLAN_WALL = `Terraform will perform the following actions:

  # azurerm_redis_cache.sessions will be created
  + resource "azurerm_redis_cache" "sessions" {
      + capacity                      = 1
      + family                        = "C"
      + hostname                      = (known after apply)
      + minimum_tls_version           = "1.2"
      + name                          = "redis-sessions"
      + public_network_access_enabled = false
      + sku_name                      = "Standard"
    }

  # azurerm_private_endpoint.redis will be created
  + resource "azurerm_private_endpoint" "redis" {
      + name      = "pe-redis-sessions"
      + subnet_id = (known after apply)
      + private_service_connection {
          + name                           = "psc-redis"
          + private_connection_resource_id = (known after apply)
          + subresource_names              = ["redisCache"]
        }
    }

  # azurerm_key_vault_secret.redis_connection will be created
  + resource "azurerm_key_vault_secret" "redis_connection" {
      + key_vault_id = (known after apply)
      + name         = "redis-connection-string"
      + value        = (sensitive value)
    }

  # azurerm_linux_web_app.api will be updated in-place
  ~ resource "azurerm_linux_web_app" "api" {
      ~ app_settings = {
          + "REDIS_HOST"    = "redis-sessions.privatelink.redis.cache.windows.net"
          + "SESSION_STORE" = "redis"
        }
    }

  # azurerm_storage_account.legacy_sessions will be destroyed
  - resource "azurerm_storage_account" "legacy_sessions" {
      - account_tier = "Standard" -> null
      - name         = "stexamplesessions" -> null
    }

Plan: 3 to add, 1 to change, 1 to destroy.`;

const WALL_LINES = PLAN_WALL.split("\n");

function wallClass(line: string): string | undefined {
  const first = line.trim()[0];
  if (first === "+") return "wall-add";
  if (first === "-") return "wall-del";
  if (first === "~") return "wall-mod";
  if (first === "#") return "wall-comment";
  return undefined;
}

const TRUST_CHIPS = [
  "No cloud credentials",
  "No state access",
  "One line in your CI",
  "Self-host or SaaS",
];
---

<div class="blueprint-grid border-b border-border">
  <section class="mx-auto max-w-6xl px-4 pt-20 pb-16 text-center sm:px-6 sm:pt-28">
    <p
      class="inline-block border border-border-strong bg-card px-3 py-1 font-mono text-[11px] uppercase tracking-widest text-muted-foreground"
    >
      Built for Terraform &amp; Kubernetes teams
    </p>
    <h1
      class="mx-auto mt-6 max-w-4xl font-display text-4xl font-semibold leading-tight tracking-tight sm:text-6xl lg:text-7xl"
    >
      <span class="text-primary">See</span> your infrastructure.
      <span class="text-primary">Review</span> it.
      <span class="text-primary">Shape</span> it.
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-muted-foreground sm:text-xl">
      Groundplan turns your infrastructure code into living, interactive diagrams. Every pull
      request becomes a picture of what changes — and your architecture docs redraw themselves
      on every merge.
    </p>

    <div class="mt-9 flex flex-wrap items-center justify-center gap-4">
      <a
        href="#product"
        class="bg-primary px-7 py-3 text-base font-medium text-primary-foreground shadow-lg shadow-primary/20 hover:opacity-90"
      >
        See it in action
      </a>
      <a
        href="/security/"
        class="border border-border-strong bg-card px-7 py-3 text-base font-medium text-secondary-foreground hover:border-primary hover:text-primary"
      >
        How we keep your cloud safe
      </a>
    </div>

    <ul class="mt-8 flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
      {
        TRUST_CHIPS.map((chip) => (
          <li class="flex items-center gap-2 text-sm text-muted-foreground">
            <span aria-hidden="true" class="font-mono text-create">✓</span>
            {chip}
          </li>
        ))
      }
    </ul>

    <figure class="mt-14 text-left">
      <div class="relative overflow-hidden border border-border-strong bg-card shadow-xl shadow-ink/10">
        <img
          src="/images/hero-pr-diagram.svg"
          alt="A Groundplan pull-request diagram: a created Redis cache, private endpoint and Key Vault secret in green, an updated web app in amber, a deleted storage account in dashed red, and an impacted diagnostic setting in violet, with the unchanged estate ghosted."
          width="1912"
          height="751"
          class="block h-auto w-full"
          fetchpriority="high"
        />
        <div class="hcl-wall" aria-hidden="true">
          {
            [0, 1].map((column) => (
              <pre class:list={["hcl-wall-text", column === 1 && "hidden lg:block"]}>
                {WALL_LINES.map((line) => (
                  <span class={wallClass(line)}>{line + "\n"}</span>
                ))}
              </pre>
            ))
          }
        </div>
      </div>
      <figcaption class="mt-3 text-center font-mono text-[11px] text-faint">
        A real pull request, rendered by Groundplan — the same diagram your reviewers see.
      </figcaption>
    </figure>
  </section>
</div>

<style>
  /* The HCL wall (GP-165). Absolutely positioned over the image box the
     <img width/height> already reserves, so showing or skipping it never
     shifts layout (CLS unchanged). */
  .hcl-wall {
    position: absolute;
    inset: 0;
    display: flex;
    gap: 2.5rem;
    padding: 1.25rem 1.5rem;
    background: var(--canvas);
    overflow: hidden;
    pointer-events: none;
    user-select: none;
  }
  /* The drafting edge that "parses" the wall away, riding the clip boundary. */
  .hcl-wall::after {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 2px;
    background: var(--primary);
    box-shadow: 0 0 14px 2px color-mix(in oklab, var(--primary) 45%, transparent);
    opacity: 0;
  }
  .hcl-wall-text {
    flex: 1;
    margin: 0;
    overflow: hidden;
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1.55;
    color: var(--muted-foreground);
    white-space: pre;
  }
  .wall-add {
    color: var(--create);
  }
  .wall-del {
    color: var(--delete);
  }
  .wall-mod {
    color: var(--update);
  }
  .wall-comment {
    color: var(--faint);
  }

  /* Reduced motion: the wall never appears — the static export IS the hero. */
  @media (prefers-reduced-motion: reduce) {
    .hcl-wall {
      display: none;
    }
  }
  @media (prefers-reduced-motion: no-preference) {
    .hcl-wall {
      clip-path: inset(0 0 0 0);
      animation: hcl-sweep 2200ms cubic-bezier(0.65, 0, 0.35, 1) 1100ms forwards;
    }
    .hcl-wall::after {
      opacity: 1;
      animation: hcl-edge 2200ms cubic-bezier(0.65, 0, 0.35, 1) 1100ms forwards;
    }
  }
  @keyframes hcl-sweep {
    to {
      clip-path: inset(0 0 0 100%);
    }
  }
  @keyframes hcl-edge {
    95% {
      opacity: 1;
    }
    to {
      left: 100%;
      opacity: 0;
    }
  }
</style>
