# Copy to .env and adjust as needed. Loaded via dotenv at startup.

# Runtime environment: development | production | test
NODE_ENV=development

# HTTP server bind address / port
HOST=0.0.0.0
PORT=3000

# Allowed CORS origin(s). Comma-separated list, or "*" for any.
CORS_ORIGIN=http://localhost:5173

# Postgres connection string. Matches the docker-compose.yml postgres service.
DATABASE_URL=postgres://groundplan:groundplan@localhost:5432/groundplan

# OIDC (resource server). When both are set, the API validates bearer tokens on
# every route except /healthz and /webhooks/*. Leave empty to disable auth in
# local dev (the app refuses to boot without them when NODE_ENV=production).
# These defaults match the dockerized Keycloak realm (docker compose profile "auth").
OIDC_ISSUER_URL=http://localhost:8085/realms/groundplan
OIDC_AUDIENCE=groundplan-api
