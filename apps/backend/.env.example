# Copy to .env and adjust as needed. Loaded via dotenv at startup.

# Runtime environment: development | production | test
NODE_ENV=development

# HTTP server bind address / port
HOST=0.0.0.0
PORT=3000

# Allowed CORS origin(s). Comma-separated list, or "*" for any.
CORS_ORIGIN=http://localhost:5173

# Postgres connection string. Matches the docker-compose.yml postgres service.
DATABASE_URL=postgres://groundplan:groundplan@localhost:5432/groundplan

# OIDC (resource server). The API validates bearer tokens on every route except
# /healthz and /webhooks/*. In DEVELOPMENT these default to the dockerized
# Keycloak realm below (so login works out of the box with `docker compose
# --profile auth up` — you don't need to set them). To run dev WITHOUT auth,
# set OIDC_ISSUER_URL= (empty). In PRODUCTION both are required (fail-closed).
OIDC_ISSUER_URL=http://localhost:8085/realms/groundplan
OIDC_AUDIENCE=groundplan-api

# Symmetric key for encrypting repository PATs at rest (AES-256-GCM).
# base64-encoded 32 bytes. Dev/test default to a fixed key; PRODUCTION requires
# an explicit one (generate: `openssl rand -base64 32`).
ENCRYPTION_KEY=

# AI layer (GP-62). THE KEY IS THE FEATURE FLAG: leave AI_API_KEY empty and the
# whole AI layer stays off — /ai/status reports disabled, the generation routes
# 404, and the frontend renders no AI surface. There is deliberately no dev
# default, because generating costs real money.
AI_API_KEY=
AI_MODEL=claude-opus-4-8
