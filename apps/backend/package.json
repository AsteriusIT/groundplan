{
  "name": "@groundplan/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --build",
    "start": "node dist/index.js",
    "test": "NODE_ENV=test node --import tsx --test \"src/**/*.test.ts\"",
    "migrate": "tsx src/db/migrate.cli.ts",
    "db:generate": "drizzle-kit generate",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/sensible": "^6.0.3",
    "@resvg/resvg-js": "^2.6.2",
    "ajv": "^8.17.1",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "elkjs": "^0.11.1",
    "fastify": "^5.2.1",
    "fastify-plugin": "^6.0.0",
    "jose": "^6.2.3",
    "mime-types": "^3.0.2",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.13.1",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
