{
  "name": "@groundplan/graph-parser",
  "version": "0.0.0",
  "private": true,
  "description": "Groundplan Producer B as a pure shared package: static HCL → GraphSnapshot, no server dependencies (files in as data).",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "[ -f tsconfig.build.json ] && tsc -p tsconfig.build.json || true",
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
