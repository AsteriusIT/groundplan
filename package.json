{
  "name": "groundplan",
  "version": "0.0.0",
  "private": true,
  "description": "InfraCanvas — turn Terraform into living, interactive, reviewable diagrams (working name: groundplan).",
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:backend": "pnpm --filter @groundplan/backend run dev",
    "dev:frontend": "pnpm --filter @groundplan/frontend run dev",
    "build": "pnpm -r run build",
    "start": "pnpm --filter @groundplan/backend run start",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r run clean"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
