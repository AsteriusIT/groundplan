# Keep the Docker build context small and free of secrets/artifacts.
# Both app images build from the repo root (they need the pnpm workspace
# manifests + lockfile), so this single ignore file covers every build.

# Dependencies & pnpm store
**/node_modules
.pnpm-store

# Build output (re-generated inside the image)
**/dist
**/build
**/*.tsbuildinfo

# VCS & CI
.git
.github
.scannerwork

# Secrets / local env — never bake these into an image layer
.env
.env.*
!.env.example
!.env.prod.example

# Editor / OS cruft
.idea
.vscode
**/.DS_Store

# Tests & coverage (not needed at runtime)
coverage
**/*.test.ts
**/*.test.tsx

# Docs & compose (not part of an app image)
docs
docker-compose*.yml
