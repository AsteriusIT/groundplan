{
  "name": "@groundplan/keycloak-theme",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "groundplan Keycloak theme (carbon) built with Keycloakify + shadcn/ui",
  "scripts": {
    "postinstall": "keycloakify sync-extensions",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build-keycloak-theme": "pnpm run build && keycloakify build",
    "update-kc-gen": "keycloakify update-kc-gen",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist dist_keycloak .vite"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "keycloakify": "^11.15.11",
    "lucide-react": "^0.474.0",
    "radix-ui": "^1.6.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.1",
    "@keycloakify/email-native": "~260007.0.0"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@tailwindcss/vite": "^4.0.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.13.1",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.0.6",
    "tw-animate-css": "^1.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitest": "^4.1.10",
    "vitest-axe": "^0.1.0"
  }
}